NODE_ENV=development
PORT=5001
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=food_delivery
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
